# Qwen Cloud API
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max
QWEN_EMBEDDING_MODEL=text-embedding-v3

# Memory
MEMORY_DB_PATH=data/agentos.db
MEMORY_CHROMA_PATH=data/chroma_db
MEMORY_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MEMORY_MAX_CONTEXT_TOKENS=8000

# n8n Integration
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=your_n8n_api_key_here

# WhatsApp / Telegram (optional, for bridge)
WHATSAPP_SESSION_PATH=~/.hermes/whatsapp/session
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json